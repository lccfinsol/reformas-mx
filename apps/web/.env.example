# =============================================
# Web Frontend — Variables de Entorno Vite
# Copia como .env.local para desarrollo local
# =============================================

# URL de PocketBase
# Desarrollo: http://localhost:8090
# Producción Hostinger: /hcgi/platform  (dejar vacío = usa el default)
VITE_POCKETBASE_URL=http://localhost:8090

# URL del API backend Express
# Desarrollo: http://localhost:3001
# Producción Hostinger: /hcgi/api  (dejar vacío = usa el default)
VITE_API_URL=http://localhost:3001
