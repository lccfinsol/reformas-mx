# =============================================
# Web Frontend — Variables de Entorno Vite
# Copia como .env.local para desarrollo local
# Nota: VITE_ es el prefijo requerido por Vite
# =============================================

# URL de PocketBase
# Desarrollo: http://localhost:8090
# Producción Hostinger: /hcgi/platform
VITE_POCKETBASE_URL=http://localhost:8090

# URL del API backend
# Desarrollo: http://localhost:3001
# Producción Hostinger: /hcgi/api
VITE_API_URL=http://localhost:3001
