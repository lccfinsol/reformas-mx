# =============================================
# API Backend — Variables de Entorno
# Copia este archivo como .env y configura
# =============================================

# Entorno de ejecución
NODE_ENV=development          # development | production

# Puerto del servidor Express
PORT=3001

# URL de PocketBase (local o remota)
POCKETBASE_URL=http://localhost:8090

# Credenciales del superusuario de PocketBase
# NUNCA commitear estas credenciales al repositorio
PB_SUPERUSER_EMAIL=admin@tudominio.com
PB_SUPERUSER_PASSWORD=cambiar_contraseña_segura

# CORS — origen(es) permitidos para peticiones cross-origin
# En desarrollo: http://localhost:3000
# En producción: https://tudominio.com
CORS_ORIGIN=http://localhost:3000

# Dominio del sitio en producción (Hostinger)
WEBSITE_DOMAIN=tudominio.com
